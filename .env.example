# Database Configuration
# Set the connection URL for the production/local MariaDB database
DB_URL=jdbc:mariadb://localhost:3306/gv_up?allowPublicKeyRetrieval=true&useSSL=false

# Set the database user
DB_USER=root

# Set the database password (leave empty if no password)
DB_PASSWORD=

# (Optional) Set the SQLite database URL for migrations/portable mode
SQLITE_DB_URL=jdbc:sqlite:data/gameverse.db
